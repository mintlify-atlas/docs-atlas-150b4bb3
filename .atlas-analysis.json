  "keyFeatures": [
    "Policy engine with YAML-based rules and hot-reload",
    "Hash-chained audit trail with tamper detection",
    "Human-in-the-loop approval workflows",
    "Native integrations with Claude Code, Cline, OpenClaw, and Codex",
    "MCP server proxying and policy generation",
    "LD_PRELOAD syscall interception for universal coverage",
    "Live TUI and web dashboard for monitoring",
    "SIEM integration via syslog and CEF formats",
    "Project-local policies for team-shared rules",
    "Community policy registry and sync"
  ],
  "publicApiSurface": [
